page {
  background-color: #F7F9FC;
  font-family: -apple-system, 'PingFang SC', 'Helvetica Neue', sans-serif;
  font-size: 28rpx;
  color: #333;
}

.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin: 0 24rpx 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}

.btn-primary {
  background: #4A90E2;
  color: #fff;
  border-radius: 12rpx;
  padding: 22rpx 0;
  text-align: center;
  font-size: 30rpx;
  font-weight: 500;
  border: none;
}

.btn-danger {
  background: #E25454;
  color: #fff;
  border-radius: 12rpx;
  padding: 22rpx 0;
  text-align: center;
  font-size: 30rpx;
  font-weight: 500;
  border: none;
}

.btn-outline {
  background: transparent;
  color: #4A90E2;
  border: 2rpx solid #4A90E2;
  border-radius: 12rpx;
  padding: 20rpx 0;
  text-align: center;
  font-size: 30rpx;
  font-weight: 500;
}

.status-pending  { color: #F5A623; background: #FFF8EC; }
.status-approved { color: #27AE60; background: #EAFAF1; }
.status-rejected { color: #E25454; background: #FEECEC; }
.status-cancelled{ color: #999;    background: #F5F5F5; }
.status-completed{ color: #4A90E2; background: #EBF4FF; }

.status-tag {
  display: inline-block;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #222;
  margin: 32rpx 24rpx 16rpx;
}

.empty-tip {
  text-align: center;
  color: #bbb;
  font-size: 28rpx;
  padding: 80rpx 0;
}
