<view class="reservations-page" bindtap="onPageTap">
  <scroll-view scroll-x class="filter-scroll">
    <view class="filter-tabs">
      <view wx:for="{{filters}}" wx:key="value" class="filter-tab {{activeFilter===item.value?'active':''}}" bindtap="setFilter" data-value="{{item.value}}">
        {{item.label}}
      </view>
    </view>
  </scroll-view>
  <view class="overview">
    <view class="overview-item">
      <text class="overview-value">{{overview.pending}}</text>
      <text class="overview-label">待审批</text>
    </view>
    <view class="overview-item">
      <text class="overview-value">{{overview.approved}}</text>
      <text class="overview-label">已通过</text>
    </view>
    <view class="overview-item">
      <text class="overview-value">{{overview.total}}</text>
      <text class="overview-label">总预约</text>
    </view>
  </view>
  <view wx:if="{{list.length===0}}" class="empty-tip">暂无预约记录</view>
  <view wx:for="{{list}}" wx:key="id" class="swipe-wrap" data-id="{{item.id}}" bindtouchstart="onCardTouchStart" bindtouchmove="onCardTouchMove" bindtouchend="onCardTouchEnd" bindtouchcancel="onCardTouchEnd">
    <view wx:if="{{item.can_delete}}" class="swipe-delete {{item._swipeX < 0 ? 'show' : ''}}" catchtap="deleteReservation" data-id="{{item.id}}">
      删除
    </view>
    <view class="res-card" style="transform: translateX({{item._swipeX || 0}}px);" bindtap="goDetail" data-id="{{item.id}}">
      <view class="res-header">
        <text class="res-lab">{{item.lab_name || '实验室'}}</text>
        <view class="status-tag status-{{item.status}}">{{statusText[item.status]}}</view>
      </view>
      <view class="res-body">
        <view class="res-row">
          <text class="res-label">日期</text>
          <text class="res-text">{{item.reservation_date}}</text>
        </view>
        <view class="res-row">
          <text class="res-label">时间</text>
          <text class="res-text">{{item.start_time}} - {{item.end_time}}</text>
        </view>
        <view class="res-row">
          <text class="res-label">人数</text>
          <text class="res-text">{{item.participant_count}} 人</text>
        </view>
      </view>
    </view>
  </view>
</view>