.reservations-page {
  padding: 20rpx;
  background: linear-gradient(180deg, #eef3f9, #f7f9fc);
  min-height: 100vh;
}

.overview {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 10rpx;
  margin-bottom: 16rpx;
}

.overview-item {
  padding: 14rpx 10rpx;
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.74);
  border: 1rpx solid rgba(255, 255, 255, 0.9);
  box-shadow: 0 8rpx 20rpx rgba(0, 0, 0, 0.05);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
}

.overview-value {
  color: #0f2c4c;
  font-size: 34rpx;
  font-weight: 700;
  line-height: 1;
}

.overview-label {
  color: #5a6b7c;
  font-size: 20rpx;
}

.filter-scroll {
  margin-bottom: 20rpx;
}

.filter-tabs {
  display: flex;
  gap: 14rpx;
}

.filter-tab {
  padding: 10rpx 24rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  background: rgba(255, 255, 255, 0.6);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  border: 1rpx solid rgba(255, 255, 255, 0.8);
  color: #555;
  transition: all 0.2s ease;
}

.filter-tab.active {
  background: rgba(0, 113, 227, 0.85);
  color: #fff;
  box-shadow: 0 6rpx 18rpx rgba(0, 113, 227, 0.3);
}

.swipe-wrap {
  position: relative;
  margin-bottom: 18rpx;
  border-radius: 24rpx;
  overflow: hidden;
}

.swipe-delete {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  width: 168rpx;
  background: #ef4444;
  color: #fff;
  font-size: 28rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  transition: opacity 0.16s ease;
}

.swipe-delete.show {
  opacity: 1;
}

.res-card {
  position: relative;
  z-index: 1;
  background: rgba(255, 255, 255, 0.7);
  backdrop-filter: blur(30rpx);
  -webkit-backdrop-filter: blur(30rpx);
  border-radius: 24rpx;
  padding: 24rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.8);
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.08);
  transition: transform 0.2s ease;
}

.res-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.res-lab {
  font-size: 30rpx;
  font-weight: 600;
  color: #0a2540;
  letter-spacing: 0.5rpx;
}

.status-tag {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
  backdrop-filter: blur(10rpx);
  -webkit-backdrop-filter: blur(10rpx);
  border: 1rpx solid rgba(255, 255, 255, 0.6);
}

.status-pending {
  color: #f2994a;
  background: rgba(242, 153, 74, 0.15);
}

.status-approved {
  color: #27ae60;
  background: rgba(39, 174, 96, 0.15);
}

.status-rejected {
  color: #eb5757;
  background: rgba(235, 87, 87, 0.15);
}

.status-cancelled {
  color: #6b7280;
  background: rgba(107, 114, 128, 0.12);
}

.res-body {
  margin-top: 16rpx;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.res-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.res-label {
  min-width: 64rpx;
  padding: 2rpx 10rpx;
  border-radius: 10rpx;
  background: rgba(15, 75, 120, 0.08);
  color: #375a7f;
  font-size: 20rpx;
  font-weight: 600;
  text-align: center;
}

.res-text {
  font-size: 25rpx;
  color: #4a5a6a;
}

.empty-tip {
  text-align: center;
  margin-top: 160rpx;
  font-size: 26rpx;
  color: #9aa5b1;
}
