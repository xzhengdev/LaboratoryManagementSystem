.reservations-page {
  padding: 20rpx;
  background: linear-gradient(180deg, #eef3f9, #f7f9fc);
  min-height: 100vh;
}

/* ===== 筛选栏 ===== */
.filter-scroll {
  margin-bottom: 20rpx;
}

.filter-tabs {
  display: flex;
  gap: 14rpx;
}

.filter-tab {
  padding: 10rpx 24rpx;
  border-radius: 999rpx;
  font-size: 24rpx;

  background: rgba(255,255,255,0.6);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);

  border: 1rpx solid rgba(255,255,255,0.8);
  color: #555;

  transition: all 0.2s ease;
}

.filter-tab.active {
  background: rgba(0,113,227,0.85);
  color: #fff;
  box-shadow: 0 6rpx 18rpx rgba(0,113,227,0.3);
}

/* ===== 卡片（核心玻璃感） ===== */
.res-card {
  background: rgba(255,255,255,0.65);
  backdrop-filter: blur(30rpx);
  -webkit-backdrop-filter: blur(30rpx);
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 18rpx;
  border: 1rpx solid rgba(255,255,255,0.7);
  box-shadow: 0 20rpx 60rpx rgba(0,0,0,0.08);
  transition: all 0.25s ease;
}

.res-card:active {
  transform: scale(0.97);
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.08);
}

/* ===== 头部 ===== */
.res-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.res-lab {
  font-size: 30rpx;
  font-weight: 600;
  color: #0a2540;
  letter-spacing: 0.5rpx;
}

/* ===== 状态标签（更苹果） ===== */
.status-tag {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 999rpx;

  backdrop-filter: blur(10rpx);
  -webkit-backdrop-filter: blur(10rpx);

  border: 1rpx solid rgba(255,255,255,0.6);
}

/* 不同状态 */
.status-pending {
  color: #F2994A;
  background: rgba(242,153,74,0.15);
}

.status-approved {
  color: #27AE60;
  background: rgba(39,174,96,0.15);
}

.status-rejected {
  color: #EB5757;
  background: rgba(235,87,87,0.15);
}

/* ===== 信息区 ===== */
.res-body {
  margin-top: 16rpx;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.res-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.res-label {
  min-width: 64rpx;
  padding: 2rpx 10rpx;
  border-radius: 10rpx;
  background: rgba(15, 75, 120, 0.08);
  color: #375a7f;
  font-size: 20rpx;
  font-weight: 600;
  text-align: center;
}

.res-text {
  font-size: 25rpx;
  color: #4a5a6a;
}

/* ===== 分割线（更轻） ===== */
.res-footer {
  margin-top: 16rpx;
  padding-top: 12rpx;
  border-top: 1rpx solid rgba(0,0,0,0.05);

  display: flex;
  justify-content: space-between;
}

/* ===== 空状态 ===== */
.empty-tip {
  text-align: center;
  margin-top: 160rpx;
  font-size: 26rpx;
  color: #9aa5b1;
}
