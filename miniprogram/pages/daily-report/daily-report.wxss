.page {
  min-height: 100vh;
  padding: 20rpx;
  background: #f5f7fb;
  box-sizing: border-box;
}

.card {
  background: #fff;
  border-radius: 20rpx;
  padding: 20rpx;
  box-sizing: border-box;
  margin-bottom: 20rpx;
  border: 1rpx solid #e5ecf5;
}

.title {
  font-size: 30rpx;
  font-weight: 700;
  color: #16304e;
  margin-bottom: 14rpx;
}

.form-row {
  min-height: 74rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-bottom: 1rpx solid #eef3fa;
  padding: 6rpx 0;
}

.form-col {
  margin-top: 14rpx;
}

.label {
  color: #5f7592;
  font-size: 24rpx;
  font-weight: 700;
}

.value {
  min-width: 260rpx;
  text-align: right;
  color: #1f3b5b;
  font-size: 24rpx;
}

.textarea {
  margin-top: 8rpx;
  width: 100%;
  min-height: 170rpx;
  border: 1rpx solid #d8e4f2;
  border-radius: 12rpx;
  background: #f9fbff;
  padding: 12rpx;
  box-sizing: border-box;
  color: #173150;
  font-size: 24rpx;
}

.char-count {
  margin-top: 6rpx;
  display: block;
  text-align: right;
  color: #8a9cb2;
  font-size: 20rpx;
}

.upload-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.btn-upload {
  margin: 0;
  height: 58rpx;
  line-height: 58rpx;
  border-radius: 12rpx;
  background: #edf6ff;
  color: #1f4f7d;
  font-size: 22rpx;
  border: 1rpx solid #cfe4f7;
  padding: 0 18rpx;
}

.photo-grid {
  margin-top: 10rpx;
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 10rpx;
}

.photo-wrap {
  position: relative;
}

.photo {
  width: 100%;
  height: 170rpx;
  border-radius: 12rpx;
  border: 1rpx solid #d7e4f2;
}

.remove {
  position: absolute;
  top: 6rpx;
  right: 6rpx;
  width: 34rpx;
  height: 34rpx;
  border-radius: 999rpx;
  background: rgba(0, 0, 0, 0.55);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  line-height: 1;
}

.photo-empty {
  grid-column: 1 / -1;
  height: 120rpx;
  border-radius: 12rpx;
  border: 1rpx dashed #cad9ea;
  color: #8094ab;
  font-size: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-submit {
  margin-top: 20rpx;
  height: 74rpx;
  border-radius: 14rpx;
  background: #2c7da0;
  color: #fff;
  font-size: 26rpx;
  font-weight: 700;
}

.record {
  padding: 12rpx 0;
  border-bottom: 1rpx solid #edf2f8;
}

.record:last-child {
  border-bottom: none;
}

.record-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  color: #244261;
  font-size: 23rpx;
}

.status {
  font-size: 22rpx;
  font-weight: 700;
}

.status-pending {
  color: #ad7a00;
}

.status-approved {
  color: #0f8a4b;
}

.status-rejected {
  color: #cc3f3f;
}

.record-content {
  margin-top: 8rpx;
  color: #425f7f;
  font-size: 22rpx;
  white-space: pre-wrap;
}

.thumb-row {
  margin-top: 8rpx;
  display: flex;
  gap: 8rpx;
  flex-wrap: wrap;
}

.thumb {
  width: 120rpx;
  height: 120rpx;
  border-radius: 10rpx;
  border: 1rpx solid #d8e4f0;
}

.empty {
  color: #8095ad;
  font-size: 22rpx;
}
