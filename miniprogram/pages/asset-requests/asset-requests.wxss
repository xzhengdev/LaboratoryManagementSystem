.page {
  padding: 20rpx;
  background: #f5f7fb;
  min-height: 100vh;
}

.card {
  background: #fff;
  border-radius: 18rpx;
  padding: 20rpx;
  margin-bottom: 18rpx;
  box-shadow: 0 8rpx 20rpx rgba(21, 42, 89, 0.06);
}

.budget-card {
  background: linear-gradient(135deg, #eaf4ff 0%, #f2f8ff 100%);
}

.title {
  font-size: 30rpx;
  color: #16325c;
  font-weight: 600;
  margin-bottom: 14rpx;
}

.budget-row {
  display: flex;
  justify-content: space-between;
  font-size: 24rpx;
  color: #2f4f77;
  margin-top: 8rpx;
}

.input {
  height: 78rpx;
  line-height: 78rpx;
  background: #f7f9fc;
  border: 1rpx solid #e3ebf6;
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 26rpx;
  color: #1e2b3d;
  margin-bottom: 12rpx;
  box-sizing: border-box;
}

.inline-row {
  display: flex;
  justify-content: space-between;
}

.half {
  width: 48%;
}

.textarea {
  width: 100%;
  min-height: 140rpx;
  background: #f7f9fc;
  border: 1rpx solid #e3ebf6;
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  font-size: 26rpx;
  color: #1e2b3d;
  box-sizing: border-box;
}

.amount {
  margin: 14rpx 0;
  font-size: 26rpx;
  color: #2056a0;
  font-weight: 600;
}

.submit-btn {
  background: #2d6cdf;
  color: #fff;
  border-radius: 14rpx;
  font-size: 28rpx;
}

.empty {
  font-size: 24rpx;
  color: #8b98ab;
  text-align: center;
  padding: 24rpx 0;
}

.item {
  padding: 16rpx 0;
  border-bottom: 1rpx solid #eef2f7;
}

.item:last-child {
  border-bottom: none;
}

.item-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.name {
  font-size: 28rpx;
  color: #1d2f46;
  font-weight: 600;
}

.status {
  font-size: 22rpx;
  border-radius: 999rpx;
  padding: 4rpx 14rpx;
}

.status-pending {
  background: #fff6e8;
  color: #b86f00;
}

.status-approved {
  background: #e8f8ee;
  color: #18794e;
}

.status-rejected {
  background: #ffefef;
  color: #c0392b;
}

.meta {
  margin-top: 6rpx;
  font-size: 23rpx;
  color: #607086;
}
