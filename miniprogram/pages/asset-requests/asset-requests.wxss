.page {
  min-height: 100vh;
  padding: 30rpx 0 160rpx;
  background: linear-gradient(180deg, #f5f6f8 0%, #eef1f5 100%);
  box-sizing: border-box;
}

.summary-card {
  margin: 0 20rpx 20rpx;
  padding: 26rpx 22rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.72);
  backdrop-filter: blur(18rpx);
  -webkit-backdrop-filter: blur(18rpx);
  border: 1rpx solid rgba(255, 255, 255, 0.85);
  box-shadow: 0 14rpx 36rpx rgba(0, 0, 0, 0.05);
}

.summary-title {
  color: #0f2c4c;
  font-size: 32rpx;
  font-weight: 700;
}

.summary-sub {
  margin-top: 8rpx;
  color: #5f7592;
  font-size: 24rpx;
}

.summary-grid {
  margin-top: 16rpx;
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 10rpx;
}

.summary-item {
  border-radius: 14rpx;
  padding: 12rpx 8rpx;
  text-align: center;
  background: #f4f8ff;
  border: 1rpx solid #dce8f8;
}

.summary-value {
  color: #0f2c4c;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1;
}

.summary-label {
  margin-top: 6rpx;
  display: block;
  color: #647f9f;
  font-size: 21rpx;
}

.summary-link {
  margin-top: 14rpx;
  color: #0a74ea;
  font-size: 24rpx;
  font-weight: 600;
}

.card {
  margin: 0 20rpx 20rpx;
  border-radius: 28rpx;
  padding: 26rpx 22rpx;
  background: rgba(255, 255, 255, 0.72);
  backdrop-filter: blur(18rpx);
  -webkit-backdrop-filter: blur(18rpx);
  border: 1rpx solid rgba(255, 255, 255, 0.85);
  box-shadow: 0 14rpx 36rpx rgba(0, 0, 0, 0.05);
  box-sizing: border-box;
}

.title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1c2d3f;
  margin-bottom: 14rpx;
}

.form-row {
  min-height: 74rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-bottom: 1rpx solid #eef3fa;
  padding: 6rpx 0;
}

.form-col {
  margin-top: 14rpx;
}

.inline-row {
  display: flex;
  gap: 12rpx;
}

.half {
  width: 50%;
}

.label {
  color: #5f7592;
  font-size: 24rpx;
  font-weight: 700;
}

.value {
  min-width: 260rpx;
  text-align: right;
  color: #1f3b5b;
  font-size: 24rpx;
}

.input {
  margin-top: 8rpx;
  height: 76rpx;
  line-height: 76rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.85);
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.7);
  padding: 0 18rpx;
  box-sizing: border-box;
  color: #223246;
  font-size: 26rpx;
}

.textarea {
  margin-top: 8rpx;
  width: 100%;
  min-height: 170rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.85);
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.7);
  padding: 18rpx;
  box-sizing: border-box;
  color: #223246;
  font-size: 26rpx;
}

.amount-box {
  margin-top: 16rpx;
  margin-bottom: 16rpx;
  border-radius: 14rpx;
  background: #edf4ff;
  border: 1rpx solid #d8e6fb;
  padding: 14rpx 16rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.amount-label {
  color: #5f7592;
  font-size: 23rpx;
}

.amount-value {
  color: #1f4f96;
  font-size: 32rpx;
  font-weight: 700;
}

.btn-row {
  display: flex;
  gap: 12rpx;
}

.btn {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 16rpx;
  font-size: 28rpx;
  font-weight: 600;
  padding: 0;
}

.btn-ghost {
  background: #f3f6fc;
  color: #375a7f;
  border: 1rpx solid #d7e3f3;
}

.btn-primary {
  background: linear-gradient(135deg, #0a74ea, #4ea1ff);
  color: #fff;
  border: none;
  box-shadow: 0 12rpx 28rpx rgba(10, 116, 234, 0.25);
}
