/* ===== 页面背景（苹果渐变 + 光晕） ===== */
.page {
  min-height: 100vh;
  background: linear-gradient(180deg, #f4f6f9 0%, #e9edf3 100%);
  position: relative;
}

/* 背景光晕 */
.page::before {
  content: '';
  position: absolute;
  top: -200rpx;
  left: -100rpx;
  width: 500rpx;
  height: 500rpx;
  background: radial-gradient(circle, rgba(0,113,227,0.15), transparent 70%);
  z-index: 0;
}

/* ===== 容器 ===== */
.container {
  position: relative;
  z-index: 1;
  min-height: 100vh;
  padding: 48rpx 36rpx;
  display: flex;
  flex-direction: column;
}

/* ===== 品牌区 ===== */
.brand-block {
  margin-top: 40rpx;
  margin-bottom: 60rpx;
  align-items: center;
  display: flex;
  flex-direction: column;
}

/* logo 外壳（玻璃风） */
.brand-logo-wrap {
  width: 160rpx;
  height: 160rpx;
  border-radius: 40rpx;

  background: rgba(255,255,255,0.6);
  backdrop-filter: blur(30rpx);

  box-shadow:
    0 20rpx 60rpx rgba(0,0,0,0.08),
    inset 0 1rpx 0 rgba(255,255,255,0.6);

  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

/* logo */
.brand-logo {
  width: 96rpx;
  height: 96rpx;
  display: block;
}

/* 标题 */
.brand-title {
  margin-top: 28rpx;
  font-size: 64rpx;
  font-weight: 700;
  color: #0f172a;
}

/* 副标题 */
.brand-subtitle {
  margin-top: 16rpx;
  font-size: 26rpx;
  color: rgba(0,0,0,0.5);
}

/* ===== 登录卡片（核心玻璃效果） ===== */
.login-card {
  background: rgba(255,255,255,0.65);
  backdrop-filter: blur(40rpx);

  border-radius: 36rpx;
  padding: 60rpx 40rpx;

  box-shadow:
    0 30rpx 80rpx rgba(0,0,0,0.08),
    0 10rpx 30rpx rgba(0,0,0,0.05);

  border: 1rpx solid rgba(255,255,255,0.4);
}

/* 标题 */
.card-title-main {
  font-size: 60rpx;
  font-weight: 700;
  color: #1e293b;
  display: flex;
  justify-content: center;
  align-items: center;
  text-align: center;
}

/* ===== 输入区域 ===== */
.card-fields {
  margin-top: 40rpx;
  margin-bottom: 30rpx;
  display: flex;
  flex-direction: column;
  gap: 28rpx;
}

/* 输入框容器（玻璃 + 聚焦态） */
.input-shell {
  height: 96rpx;
  border-radius: 20rpx;

  background: rgba(255,255,255,0.5);
  backdrop-filter: blur(20rpx);

  border: 1rpx solid rgba(0,0,0,0.05);

  padding: 0 20rpx;
  display: flex;
  align-items: center;
  gap: 14rpx;

  transition: all 0.25s ease;
}

/* 聚焦态 */
.input-shell:focus-within {
  border-color: #0071e3;
  box-shadow: 0 0 0 4rpx rgba(0,113,227,0.12);
}

/* icon */
.input-icon {
  width: 56rpx;
  height: 48rpx;
  border-radius: 12rpx;

  background: rgba(0,0,0,0.05);
  color: #64748b;

  font-size: 22rpx;

  display: flex;
  align-items: center;
  justify-content: center;
}

/* 输入框 */
.input {
  flex: 1;
  padding-left: 13rpx; 
  font-size: 32rpx;
  color: #1e293b;
}
.placeholder {
  color: rgba(0,0,0,0.35);
  font-size: 28rpx;
  opacity: 0.6;
}
/* ===== 辅助区域 ===== */
.assist-row {
  margin: 20rpx 0 36rpx;
  display: flex;
  justify-content: space-between;
}

/* 记住密码 */
.remember-wrap {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.remember-dot {
  width: 28rpx;
  height: 28rpx;
  border-radius: 50%;
  background: #d1d9e6;
}

.remember-dot.active {
  background: #0071e3;
  box-shadow: 0 0 0 6rpx rgba(0,113,227,0.12);
}

.remember-text,
.forgot {
  font-size: 26rpx;
  color: rgba(0,0,0,0.5);
}

/* ===== 登录按钮（苹果质感） ===== */
.submit {
  width: 100%;
  height: 90rpx;
  line-height: 90rpx;
  border-radius: 45rpx;

  font-size: 32rpx;
  font-weight: 600;
  color: #fff;

  background: linear-gradient(135deg, #0071e3, #4da3ff);

  box-shadow:
    0 14rpx 32rpx rgba(0,113,227,0.25),
    inset 0 1rpx 0 rgba(255,255,255,0.4);

  transition: all 0.2s ease;
}

.submit:active {
  transform: scale(0.96);
  box-shadow: 0 6rpx 14rpx rgba(0,113,227,0.2);
}

.submit::after {
  border: none;
}

/* ===== 底部 ===== */
.login-page__bottom {
  margin-top: auto;
  padding-top: 50rpx;
}

.login-footer {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 18rpx;
}

.login-footer__line {
  width: 100rpx;
  height: 2rpx;
  background: rgba(0,0,0,0.15);
}

.login-footer__text {
  font-size: 24rpx;
  color: rgba(0,0,0,0.4);
}
