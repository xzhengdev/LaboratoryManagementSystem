.login-page {
  min-height: 100vh;
  background: linear-gradient(160deg, #4A90E2 0%, #2c6fbe 40%, #F7F9FC 40%);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 120rpx;
}

.login-hero {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 48rpx;
}

.hero-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.hero-title {
  font-size: 44rpx;
  font-weight: 700;
  color: #fff;
  letter-spacing: 2rpx;
}

.hero-sub {
  font-size: 26rpx;
  color: rgba(255,255,255,0.8);
  margin-top: 8rpx;
}

.login-form {
  width: 680rpx;
  padding: 40rpx 36rpx;
}

.role-row {
  display: flex;
  gap: 16rpx;
  margin-bottom: 36rpx;
  flex-wrap: wrap;
}

.role-chip {
  flex: 1;
  min-width: 140rpx;
  text-align: center;
  padding: 14rpx 0;
  border-radius: 40rpx;
  font-size: 26rpx;
  color: #666;
  background: #F0F4FA;
  border: 2rpx solid transparent;
}

.role-chip.active {
  color: #4A90E2;
  background: #EBF4FF;
  border-color: #4A90E2;
  font-weight: 600;
}

.field {
  margin-bottom: 28rpx;
}

.field-label {
  font-size: 26rpx;
  color: #666;
  display: block;
  margin-bottom: 10rpx;
}

.field-input {
  width: 100%;
  height: 88rpx;
  background: #F7F9FC;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
  border: 2rpx solid #E8EDF5;
}

.login-btn {
  width: 100%;
  margin-top: 16rpx;
  font-size: 32rpx;
  letter-spacing: 4rpx;
}
