.labs-page {
  min-height: 100vh;
  background: linear-gradient(180deg, #eef3f9, #f7f9fc);
  padding-bottom: 44rpx;
}

/* ===== 顶部筛选区（轻玻璃） ===== */
.filter-row {
  display: flex;
  align-items: center;
  gap: 14rpx;
  padding: 20rpx 24rpx 14rpx;

  background: rgba(255,255,255,0.7);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);

  border-bottom: 1rpx solid rgba(255,255,255,0.6);
}

/* 校区选择 */
.picker-wrap {
  width: 220rpx;
  flex-shrink: 0;
}

.picker {
  height: 72rpx;
  padding: 0 20rpx;
  border-radius: 16rpx;

  background: rgba(255,255,255,0.5);
  backdrop-filter: blur(20rpx);

  border: 1rpx solid rgba(255,255,255,0.8);

  display: flex;
  align-items: center;
  justify-content: space-between;
}

.picker-text {
  font-size: 26rpx;
  color: #1f2d3d;
  font-weight: 500;
}

.arrow {
  font-size: 20rpx;
  color: #7a8ca5;
}

/* 搜索框（苹果输入框） */
.search-box {
  flex: 1;
  height: 72rpx;
  border-radius: 18rpx;

  background: rgba(255,255,255,0.6);
  backdrop-filter: blur(20rpx);

  border: 1rpx solid rgba(255,255,255,0.8);

  display: flex;
  align-items: center;
  padding: 0 18rpx;
}

.search-icon {
  font-size: 26rpx;
  color: #9aa6b2;
  margin-right: 10rpx;
}

.search-input {
  flex: 1;
  height: 72rpx;
  font-size: 26rpx;
  color: #223042;
}

.search-placeholder {
  color: #a0a8b5;
}

/* ===== 类型筛选（胶囊玻璃） ===== */
.type-scroll {
  background: rgba(255,255,255,0.6);
  backdrop-filter: blur(20rpx);
  padding: 12rpx 0 20rpx;
  border-bottom: 1rpx solid rgba(255,255,255,0.6);
}

.type-tabs {
  display: flex;
  gap: 14rpx;
  padding: 0 24rpx;
}

.type-tab {
  flex-shrink: 0;
  min-width: 98rpx;
  height: 58rpx;
  padding: 0 24rpx;
  border-radius: 999rpx;
  background: rgba(255,255,255,0.5);
  border: 1rpx solid rgba(255,255,255,0.8);
  color: #2d4f79;
  font-size: 24rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s ease;
}

.type-tab.active {
  background: rgba(76,177,245,0.9);
  color: #fff;

  box-shadow: 0 6rpx 20rpx rgba(76,177,245,0.35);
}

/* ===== 空状态 ===== */
.empty-tip {
  margin: 140rpx 24rpx;
  text-align: center;
  font-size: 27rpx;
  color: #8b98a8;
}

/* ===== 卡片（核心苹果玻璃） ===== */
.lab-card {
  margin: 18rpx 16rpx 0;
  padding: 18rpx;
  border-radius: 26rpx;
  background: rgba(255,255,255,0.65);
  backdrop-filter: blur(30rpx);
  -webkit-backdrop-filter: blur(30rpx);
  border: 1rpx solid rgba(255,255,255,0.8);
  box-shadow: 0 20rpx 60rpx rgba(0,0,0,0.08);
  display: flex;
  align-items: center;
  transition: all 0.25s ease;
}

.lab-card:active {
  transform: scale(0.97);
  box-shadow: 0 6rpx 16rpx rgba(0,0,0,0.08);
}

/* 图片 */
.lab-img-wrap {
  width: 170rpx;
  height: 132rpx;
  border-radius: 18rpx;
  overflow: hidden;
  flex-shrink: 0;
}

.lab-img {
  width: 100%;
  height: 100%;
}

.lab-img.fallback {
  display: flex;
  align-items: center;
  justify-content: center;
}

.lab-char {
  font-size: 48rpx;
  font-weight: 700;
  color: #fff;
}

/* 主体信息 */
.lab-main {
  flex: 1;
  margin-left: 18rpx;
}

.lab-head {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.lab-name {
  flex: 1;
  font-size: 30rpx;
  line-height: 1.4;
  color: #0f2c4c;
  font-weight: 700;
}

/* 状态（更轻） */
.lab-status {
  flex-shrink: 0;
  height: 40rpx;
  font-weight: 600;
  padding: 0 12rpx;
  border-radius: 80rpx;
  font-size: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.lab-status.active {
  color: #fff;
  background: rgba(76,177,245,0.9);
}

.lab-status.inactive {
  color: #7f8c9c;
  background: rgba(240,244,249,0.7);
}

/* 次级信息 */
.lab-campus {
  margin-top: 6rpx;
  font-size: 23rpx;
  color: #5c789a;
}

.lab-loc {
  margin-top: 4rpx;
  font-size: 23rpx;
  color: #6a7d92;
}

/* 标签 */
.lab-meta {
  margin-top: 10rpx;
  display: flex;
  gap: 8rpx;
  flex-wrap: wrap;
}

.meta-tag {
  height: 40rpx;
  padding: 0 14rpx;
  border-radius: 14rpx;

  background: rgba(230,241,255,0.7);
  backdrop-filter: blur(10rpx);

  color: #4f647c;
  font-size: 21rpx;

  display: inline-flex;
  align-items: center;
}

/* 右箭头 */
.lab-arrow {
  margin-left: 10rpx;
  font-size: 40rpx;
  color: rgba(120,140,170,0.7);
}