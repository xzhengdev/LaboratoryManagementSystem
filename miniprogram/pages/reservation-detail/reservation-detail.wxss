.detail-page { padding-bottom: 140rpx; }

.status-banner {
  padding: 40rpx 32rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}
.status-banner-pending  { background: linear-gradient(135deg,#F5A623,#e09010); }
.status-banner-approved { background: linear-gradient(135deg,#27AE60,#1e8449); }
.status-banner-rejected { background: linear-gradient(135deg,#E25454,#c0392b); }
.status-banner-cancelled{ background: linear-gradient(135deg,#999,#777); }
.status-banner-completed{ background: linear-gradient(135deg,#4A90E2,#2c6fbe); }

.banner-status-text { font-size: 44rpx; font-weight: 700; color: #fff; }
.banner-status-sub  { font-size: 26rpx; color: rgba(255,255,255,0.85); }

.card-title { font-size: 28rpx; font-weight: 600; color: #333; display: block; margin-bottom: 16rpx; }

.info-row {
  display: flex;
  justify-content: space-between;
  padding: 14rpx 0;
  border-bottom: 1rpx solid #F5F7FA;
}
.info-row:last-child { border-bottom: none; }
.info-k { font-size: 26rpx; color: #888; }
.info-v { font-size: 26rpx; color: #333; font-weight: 500; }

.purpose-text { font-size: 26rpx; color: #555; line-height: 1.7; }

.approval-item { display: flex; gap: 16rpx; padding: 16rpx 0; border-bottom: 1rpx solid #F5F7FA; }
.approval-item:last-child { border-bottom: none; }

.approval-dot {
  width: 20rpx; height: 20rpx;
  border-radius: 50%;
  margin-top: 8rpx;
  flex-shrink: 0;
}
.approval-dot.status-dot-approved { background: #27AE60; }
.approval-dot.status-dot-rejected { background: #E25454; }
.approval-dot.status-dot-pending  { background: #F5A623; }

.approval-body { flex: 1; display: flex; flex-direction: column; gap: 6rpx; }
.approval-header { display: flex; justify-content: space-between; align-items: center; }
.approval-approver { font-size: 26rpx; font-weight: 500; color: #333; }
.approval-remark { font-size: 24rpx; color: #666; }
.approval-time { font-size: 22rpx; color: #bbb; }

.action-bar {
  position: fixed;
  bottom: 0; left: 0; right: 0;
  background: #fff;
  padding: 20rpx 32rpx;
  box-shadow: 0 -2rpx 12rpx rgba(0,0,0,0.08);
}
.cancel-btn { width: 100%; }
