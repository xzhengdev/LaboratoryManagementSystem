<view class="home-page">
  <swiper
    class="banner"
    autoplay
    interval="3000"
    circular
    indicator-dots
    indicator-color="rgba(255,255,255,0.5)"
    indicator-active-color="#fff"
  >
    <swiper-item wx:for="{{banners}}" wx:key="index">
      <view class="banner-slide">
        <image class="banner-image" src="{{item.image}}" mode="aspectFill" />
        <view class="banner-mask"></view>
        <view class="banner-content">
          <text class="banner-title">{{item.title}}</text>
          <text class="banner-sub">{{item.sub}}</text>
        </view>
      </view>
    </swiper-item>
  </swiper>

  <view class="entries">
    <view class="entry-item" bindtap="goCampuses">
      <view class="entry-icon" style="background:#EBF4FF">
        <image class="entry-icon-image" src="/assets/tabbar/home.png" mode="aspectFit" />
      </view>
      <text class="entry-label">校区</text>
    </view>
    <view class="entry-item" bindtap="goLabs">
      <view class="entry-icon" style="background:#FFF3E0">
        <image class="entry-icon-image" src="/assets/tabbar/labs.png" mode="aspectFit" />
      </view>
      <text class="entry-label">实验室</text>
    </view>
    <view class="entry-item" bindtap="goReservations">
      <view class="entry-icon" style="background:#E8F5E9">
        <image class="entry-icon-image" src="/assets/tabbar/reserve.png" mode="aspectFit" />
      </view>
      <text class="entry-label">我的预约</text>
    </view>
    <view class="entry-item" bindtap="goAgent">
      <view class="entry-icon" style="background:#F3E5F5">
        <image class="entry-icon-image" src="/assets/logo.png" mode="aspectFit" />
      </view>
      <text class="entry-label">AI助手</text>
    </view>
  </view>

  <view wx:if="{{canReportDaily}}" class="daily-report-entry" bindtap="goDailyReport">
    <view class="daily-report-entry__left">
      <text class="daily-report-entry__title">实验室日报</text>
      <text class="daily-report-entry__sub">拍照上报每日实验室使用情况</text>
    </view>
    <text class="daily-report-entry__arrow">></text>
  </view>

  <view class="notice-entry" bindtap="goNotifications">
    <view class="notice-entry__left">
      <text class="notice-entry__title">消息中心</text>
      <text class="notice-entry__sub">查看日报审核结果与系统通知</text>
    </view>
    <view class="notice-entry__right">
      <text wx:if="{{unreadNoticeCount > 0}}" class="notice-badge">{{unreadNoticeCount}}</text>
      <text class="notice-entry__arrow">></text>
    </view>
  </view>

  <text class="section-title">推荐实验室</text>
  <view wx:if="{{labs.length === 0}}" class="empty-tip">暂无数据</view>
  <view
    wx:for="{{labs}}"
    wx:key="id"
    class="lab-card card"
    bindtap="goLabDetail"
    data-id="{{item.id}}"
  >
    <view class="lab-card-inner">
      <view class="lab-cover">
        <image
          wx:if="{{item.photos && item.photos.length}}"
          class="lab-cover-image"
          src="{{item.photos[0]}}"
          mode="aspectFill"
        />
        <text wx:else class="lab-cover-text">{{item.lab_name[0]}}</text>
      </view>
      <view class="lab-info">
        <text class="lab-name">{{item.lab_name}}</text>
        <text class="lab-meta">容量 {{item.capacity}} 人 · {{item.open_time}}-{{item.close_time}}</text>
        <text class="lab-campus">{{item.campus_name || ''}}</text>
      </view>
    </view>
  </view>
</view>
