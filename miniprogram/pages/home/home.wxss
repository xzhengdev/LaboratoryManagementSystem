/* ===== 页面背景 ===== */
.home-page {
  padding: 16rpx;
  padding-bottom: 40rpx;
  background: linear-gradient(180deg, #f5f6f8 0%, #eef1f5 100%);
  min-height: 100vh;
}

/* ===== Banner（升级） ===== */
.banner {
  height: 340rpx;
  width: 100%;
  border-radius: 24rpx;
  overflow: hidden;
  margin-bottom: 16rpx;
}

.banner-slide {
  position: relative;
  height: 340rpx;
  border-radius: 24rpx;
  overflow: hidden;
}

.banner-image {
  width: 100%;
  height: 100%;
  display: block;
}

.banner-mask {
  position: absolute;
  inset: 0;
  background: linear-gradient(180deg, rgba(6, 19, 39, 0.08) 0%, rgba(6, 19, 39, 0.46) 100%);
}

.banner-content {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 0 40rpx 30rpx;
  display: flex;
  flex-direction: column;
}

/* 标题 */
.banner-title {
  font-size: 42rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 10rpx;
}

/* 副标题 */
.banner-sub {
  font-size: 26rpx;
  color: rgba(255,255,255,0.85);
}

/* ===== 快捷入口（卡片化） ===== */
.entries {
  display: flex;
  justify-content: space-between;
  padding: 20rpx 16rpx;
  border-radius: 20rpx;
  background: rgba(255,255,255,0.7);
  backdrop-filter: blur(20rpx);
  box-shadow: 0 10rpx 30rpx rgba(0,0,0,0.06);
  margin-bottom: 20rpx;
}
.entry-item {
  position: relative;
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

/* icon（升级） */
.entry-icon {
  width: 88rpx;
  height: 88rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;

  box-shadow: 0 6rpx 16rpx rgba(0,0,0,0.08);
}

.entry-icon-image {
  width: 42rpx;
  height: 42rpx;
  display: block;
}

/* label */
.entry-label {
  font-size: 24rpx;
  color: rgba(0,0,0,0.6);
}

.entry-item--with-badge .entry-icon {
  position: relative;
}

.entry-corner-badge {
  position: absolute;
  top: -2rpx;
  right: 26rpx;
  min-width: 36rpx;
  height: 36rpx;
  border-radius: 999rpx;
  padding: 0 8rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  background: #e64545;
  box-shadow: 0 4rpx 12rpx rgba(230, 69, 69, 0.35);
  z-index: 2;
}

.entry-corner-badge--pill {
  min-width: 48rpx;
  padding: 0 10rpx;
}

.entry-corner-badge-text {
  color: #fff;
  font-size: 20rpx;
  line-height: 1;
  font-weight: 600;
}

/* ===== 标题 ===== */
.section-title {
  font-size: 32rpx;
  font-weight: 600;
  margin: 16rpx 0 8rpx;   /* 左右不要再单独加 */
  color: #111;
}


/* 空状态 */
.empty-tip {
  text-align: center;
  color: rgba(0,0,0,0.4);
  margin-top: 80rpx;
}

/* ===== 实验室卡片（核心升级） ===== */
.lab-card {
  margin-top: 20rpx;
  margin-left: 0;         /* 关键 */
  margin-right: 0;        /* 关键 */
  border-radius: 26rpx;
  background: rgba(255,255,255,0.55);
  backdrop-filter: blur(30rpx);
  -webkit-backdrop-filter: blur(30rpx);
  border: 1rpx solid rgba(255,255,255,0.8);
  box-shadow:
    0 14rpx 40rpx rgba(0,0,0,0.06),
    inset 0 1rpx 0 rgba(255,255,255,0.9);
  overflow: hidden;
  transition: all 0.25s ease;
}

/* 点击反馈 */
.lab-card:active {
  transform: scale(0.97);
  box-shadow: 0 6rpx 16rpx rgba(0,0,0,0.08);
}

/* 卡片内容 */
.lab-card-inner {
  display: flex;
  align-items: center;
  /* padding: 22rpx; */
  gap: 24rpx;
}

/* 封面 */
.lab-cover {
  width: 150rpx;
  height: 110rpx;
  border-radius: 20rpx;
  flex-shrink: 0;
  overflow: hidden;
  background: #4A90E2;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow:
    0 8rpx 18rpx rgba(0,0,0,0.1),
    inset 0 2rpx 6rpx rgba(255,255,255,0.6);
}

.lab-cover-image {
  width: 100%;
  height: 100%;
}

/* 封面字 */
.lab-cover-text {
  font-size: 36rpx;
  color: #fff;
  font-weight: 700;
}

/* 信息区 */
.lab-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

/* 名字 */
.lab-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #0f2c4c;
}

/* 元信息 */
.lab-meta {
  font-size: 24rpx;
  color: #5a6b7c;
}

/* 校区 */
.lab-campus {
  font-size: 22rpx;
  color: #6c7d8f;
}

/* 箭头 */
.lab-arrow {
  font-size: 34rpx;
  color: rgba(120,140,170,0.6);
}
