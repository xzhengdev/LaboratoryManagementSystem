.reserve-page {
  min-height: 100vh;
  padding: 30rpx 0 180rpx;
  background: linear-gradient(180deg, #f5f6f8 0%, #eef1f5 100%);
  box-sizing: border-box;
}

.card {
  border-radius: 28rpx;
  padding: 26rpx 22rpx;
  margin-bottom: 20rpx;
  background: rgba(255, 255, 255, 0.72);
  backdrop-filter: blur(18rpx);
  -webkit-backdrop-filter: blur(18rpx);
  border: 1rpx solid rgba(255, 255, 255, 0.85);
  box-shadow: 0 14rpx 36rpx rgba(0, 0, 0, 0.05);
}

.lab-summary {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.lab-summary-name {
  font-size: 34rpx;
  font-weight: 700;
  color: #0f2c4c;
}

.lab-summary-loc {
  font-size: 24rpx;
  color: #6c7d8f;
}

.timeline-card {
  gap: 18rpx;
  display: flex;
  flex-direction: column;
}

.timeline-header {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1c2d3f;
}

.timeline-note {
  font-size: 22rpx;
  color: #7d8d9d;
}

.timeline-track {
  position: relative;
  height: 44rpx;
  border-radius: 22rpx;
  background: #d9ebe4;
  overflow: hidden;
}

.timeline-block {
  position: absolute;
  top: 0;
  bottom: 0;
}

.timeline-block-busy {
  background: rgba(38, 59, 86, 0.62);
}

.timeline-block-selected {
  background: #1786c8;
}

.timeline-range {
  display: flex;
  justify-content: space-between;
  font-size: 30rpx;
  color: #6f7f8f;
}

.form-card {
  padding: 0;
  overflow: hidden;
}

.form-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 26rpx 22rpx;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.04);
}

.form-row-tap {
  cursor: pointer;
}

.form-label {
  font-size: 28rpx;
  color: #6b7c8f;
}

.form-val-wrap {
  display: flex;
  align-items: center;
}

.form-val {
  font-size: 28rpx;
  color: #0a74ea;
  font-weight: 500;
}

.option-tip {
  padding: 16rpx 22rpx 22rpx;
  color: #c06262;
  font-size: 24rpx;
}

.count-ctrl {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.count-btn {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(74, 144, 226, 0.1);
  color: #4a90e2;
  font-size: 34rpx;
  font-weight: 700;
}

.count-val {
  font-size: 32rpx;
  font-weight: 600;
  color: #111;
  min-width: 40rpx;
  text-align: center;
}

.form-col {
  padding: 24rpx 22rpx;
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.purpose-input {
  width: 100%;
  height: 170rpx;
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.7);
  border: 1rpx solid rgba(255, 255, 255, 0.85);
  padding: 18rpx;
  font-size: 26rpx;
  color: #223246;
  box-sizing: border-box;
}

.char-count {
  font-size: 22rpx;
  color: #9aa6b2;
  text-align: right;
}

.sched-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.04);
}

.sched-row:last-child {
  border-bottom: none;
}

.sched-time {
  font-size: 26rpx;
  color: #223246;
}

.submit-bar {
  position: fixed;
  left: 20rpx;
  right: 20rpx;
  bottom: calc(20rpx + env(safe-area-inset-bottom));
}

.submit-btn {
  width:40%;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #0a74ea, #4ea1ff);
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
  box-shadow: 0 12rpx 28rpx rgba(10, 116, 234, 0.25);
}

.time-panel-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.35);
  z-index: 20;
}

.time-panel {
  position: fixed;
  left: 20rpx;
  right: 20rpx;
  bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: #fff;
  border-radius: 26rpx;
  z-index: 21;
  overflow: hidden;
}

.time-panel-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 22rpx;
  border-bottom: 1rpx solid #edf1f5;
}

.time-panel-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1c2d3f;
}

.time-panel-close {
  font-size: 26rpx;
  color: #1f7ed0;
}

.time-panel-options {
  max-height: 520rpx;
  padding: 16rpx 18rpx 26rpx;
  box-sizing: border-box;
}

.time-option {
  padding: 18rpx 20rpx;
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #26445f;
  background: #f4f8fc;
  margin-bottom: 14rpx;
}

.time-option-active {
  background: #dcedff;
  color: #0b5fa8;
  font-weight: 600;
}
