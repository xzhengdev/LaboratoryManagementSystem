<view class="reserve-page">
  <view class="card lab-summary">
    <text class="lab-summary-name">{{lab.lab_name}}</text>
    <text class="lab-summary-loc">位置：{{lab.location || '-'}}</text>
  </view>

  <view class="card timeline-card">
    <view class="timeline-header">
      <text class="card-title">时间可视化</text>
      <text class="timeline-note">深色为已占用，蓝色为当前选择</text>
    </view>
    <view class="timeline-track">
      <view
        wx:for="{{busyTimelineBlocks}}"
        wx:key="index"
        class="timeline-block timeline-block-busy"
        style="left: {{item.left}}%; width: {{item.width}}%;"
      ></view>
      <view
        wx:if="{{selectedTimeline.visible}}"
        class="timeline-block timeline-block-selected"
        style="left: {{selectedTimeline.left}}%; width: {{selectedTimeline.width}}%;"
      ></view>
    </view>
    <view class="timeline-range">
      <text>{{openTime}}</text>
      <text>{{closeTime}}</text>
    </view>
  </view>

  <view class="card form-card">
    <view class="form-row">
      <text class="form-label">预约日期</text>
      <picker mode="date" value="{{form.date}}" start="{{minDate}}" end="{{maxDate}}" bindchange="onDate">
        <view class="form-val">{{form.date}} ›</view>
      </picker>
    </view>

    <view class="form-row form-row-tap" bindtap="openTimePanel" data-field="start">
      <text class="form-label">开始时间</text>
      <view class="form-val-wrap">
        <text class="form-val">{{form.start_time || '请选择'}} ›</text>
      </view>
    </view>

    <view class="form-row form-row-tap" bindtap="openTimePanel" data-field="end">
      <text class="form-label">结束时间</text>
      <view class="form-val-wrap">
        <text class="form-val">{{form.end_time || '请选择'}} ›</text>
      </view>
    </view>

    <view class="option-tip" wx:if="{{!availableStartTimes.length}}">
      当前日期没有可预约时间，请切换日期。
    </view>

    <view class="form-row">
      <text class="form-label">参与人数</text>
      <view class="count-ctrl">
        <view class="count-btn" bindtap="decCount">-</view>
        <text class="count-val">{{form.participant_count}}</text>
        <view class="count-btn" bindtap="incCount">+</view>
      </view>
    </view>

    <view class="form-col">
      <text class="form-label">使用目的</text>
      <textarea
        class="purpose-input"
        placeholder="请简要描述使用目的（必填）"
        value="{{form.purpose}}"
        bindinput="onPurpose"
        maxlength="200"
      />
      <text class="char-count">{{form.purpose.length}}/200</text>
    </view>
  </view>

  <!-- <view class="card" wx:if="{{schedule.length > 0}}">
    <text class="card-title">当日排期</text>
    <view wx:for="{{schedule}}" wx:key="id" class="sched-row">
      <text class="sched-time">{{item.start_label}} - {{item.end_label}}</text>
      <text class="sched-status status-tag status-{{item.status}}">{{item.status_label}}</text>
    </view>
  </view> -->

  <view class="submit-bar">
    <button class="btn-primary submit-btn" bindtap="doSubmit" loading="{{loading}}">提交预约</button>
  </view>

  <view wx:if="{{timePanelVisible}}" class="time-panel-mask" bindtap="closeTimePanel"></view>
  <view wx:if="{{timePanelVisible}}" class="time-panel">
    <view class="time-panel-head">
      <text class="time-panel-title">{{timePanelTitle}}</text>
      <text class="time-panel-close" bindtap="closeTimePanel">关闭</text>
    </view>
    <scroll-view class="time-panel-options" scroll-y>
      <view
        wx:for="{{timePanelOptions}}"
        wx:key="index"
        class="time-option {{(timePanelField==='start' && item===form.start_time) || (timePanelField==='end' && item===form.end_time) ? 'time-option-active' : ''}}"
        data-value="{{item}}"
        bindtap="chooseTimeOption"
      >
        {{item}}
      </view>
    </scroll-view>
  </view>
</view>
