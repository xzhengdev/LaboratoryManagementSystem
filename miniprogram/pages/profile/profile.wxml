<view class="profile-page">
  <!-- Avatar & name -->
  <view class="profile-hero">
    <view class="avatar-wrap" bindtap="{{editing ? 'changeAvatar' : ''}}">
      <image wx:if="{{profile.avatar_url}}" class="avatar" src="{{profile.avatar_url}}" mode="aspectFill" />
      <view wx:else class="avatar-placeholder">{{profile.username ? profile.username[0].toUpperCase() : '?'}}</view>
      <view class="avatar-edit-badge" wx:if="{{editing}}">换</view>
    </view>
    <text class="profile-name">{{profile.real_name || profile.username}}</text>
    <view class="role-badge">{{roleText[profile.role]}}</view>
  </view>

  <!-- Info / Edit form -->
  <view class="info-card">
    <view class="info-row">
      <text class="info-k">用户名</text>
      <text class="info-v">{{profile.username}}</text>
    </view>
    <view class="info-row">
      <text class="info-k">姓名</text>
      <input wx:if="{{editing}}" class="edit-input" value="{{editForm.real_name}}" bindinput="onRealName" placeholder="请输入姓名" placeholder-style="color: rgba(0,0,0,0.48);" />
      <text wx:else class="info-v {{!profile.real_name ? 'empty' : ''}}">{{profile.real_name || '—'}}</text>
    </view>
    <view class="info-row">
      <text class="info-k">邮箱</text>
      <input wx:if="{{editing}}" class="edit-input" value="{{editForm.email}}" bindinput="onEmail" placeholder="请输入邮箱" placeholder-style="color: rgba(0,0,0,0.48);" />
      <text wx:else class="info-v {{!profile.email ? 'empty' : ''}}">{{profile.email || '—'}}</text>
    </view>
    <view class="info-row">
      <text class="info-k">手机</text>
      <input wx:if="{{editing}}" class="edit-input" value="{{editForm.phone}}" bindinput="onPhone" placeholder="请输入手机号" placeholder-style="color: rgba(0,0,0,0.48);" />
      <text wx:else class="info-v {{!profile.phone ? 'empty' : ''}}">{{profile.phone || '—'}}</text>
    </view>
    <view class="info-row" bindtap="openPasswordDialog">
      <text class="info-k">密码</text>
      <view class="info-action">
        <text class="info-action__text">修改密码</text>
        <text class="info-action__arrow">›</text>
      </view>
    </view>
  </view>

  <view wx:if="{{passwordDialogVisible}}" class="password-mask" bindtap="closePasswordDialog">
    <view class="password-dialog" catchtap="noop">
      <view class="password-dialog__title">修改密码</view>
      <input class="password-input" password value="{{passwordForm.old_password}}" bindinput="onOldPassword" placeholder="请输入原密码" placeholder-style="color: rgba(0,0,0,0.35);" />
      <input class="password-input" password value="{{passwordForm.new_password}}" bindinput="onNewPassword" placeholder="请输入新密码（至少 6 位）" placeholder-style="color: rgba(0,0,0,0.35);" />
      <input class="password-input" password value="{{passwordForm.confirm_password}}" bindinput="onConfirmPassword" placeholder="请再次输入新密码" placeholder-style="color: rgba(0,0,0,0.35);" />
      <view class="password-dialog__actions">
        <button class="btn-outline password-dialog__btn" bindtap="closePasswordDialog">取消</button>
        <button class="btn-primary password-dialog__btn" loading="{{changingPassword}}" bindtap="changePassword">确认</button>
      </view>
    </view>
  </view>

  <view class="action-group">
  <view class="primary-actions">
    <button wx:if="{{!editing}}" class="btn-primary" bindtap="startEdit">编辑资料</button>

    <view wx:else class="edit-actions">
      <button class="btn-primary" bindtap="saveEdit">保存</button>
      <button class="btn-outline" bindtap="cancelEdit">取消</button>
    </view>
  </view>
</view>

<view class="logout-fixed">
  <button class="btn-logout" bindtap="doLogout">退出登录</button>
</view>

<!-- Loading overlay -->
<view wx:if="{{globalLoading}}" class="loading-overlay">
  <view class="loading-spinner"></view>
</view>
</view>
