.profile-page { padding-bottom: 60rpx; }

.profile-hero {
  background: linear-gradient(135deg, #4A90E2, #2c6fbe);
  padding: 60rpx 32rpx 48rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.avatar-wrap { position: relative; }

.avatar {
  width: 140rpx; height: 140rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255,255,255,0.6);
}

.avatar-placeholder {
  width: 140rpx; height: 140rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.25);
  display: flex; align-items: center; justify-content: center;
  font-size: 56rpx; color: #fff; font-weight: 700;
  border: 4rpx solid rgba(255,255,255,0.6);
}

.avatar-edit-badge {
  position: absolute; bottom: 0; right: 0;
  background: #fff; color: #4A90E2;
  width: 44rpx; height: 44rpx;
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-size: 20rpx; font-weight: 700;
}

.profile-name { font-size: 36rpx; font-weight: 700; color: #fff; }

.role-badge {
  background: rgba(255,255,255,0.2);
  color: #fff;
  padding: 6rpx 24rpx;
  border-radius: 30rpx;
  font-size: 24rpx;
}

.info-card { margin-top: 24rpx; padding: 0; }

.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 24rpx;
  border-bottom: 1rpx solid #F5F7FA;
}
.info-row:last-child { border-bottom: none; }
.info-k { font-size: 26rpx; color: #888; flex-shrink: 0; width: 100rpx; }
.info-v { font-size: 26rpx; color: #333; text-align: right; }

.edit-input {
  flex: 1;
  text-align: right;
  font-size: 26rpx;
  color: #333;
  border-bottom: 2rpx solid #4A90E2;
  padding-bottom: 4rpx;
}

.action-group { padding: 32rpx 24rpx; display: flex; flex-direction: column; gap: 20rpx; }
.action-btn { width: 100%; }

.edit-actions { display: flex; gap: 16rpx; }
.edit-actions .action-btn { flex: 1; }

.btn-logout {
  width: 100%;
  background: transparent;
  color: #E25454;
  border: 2rpx solid #E25454;
  border-radius: 12rpx;
  padding: 22rpx 0;
  font-size: 30rpx;
}
