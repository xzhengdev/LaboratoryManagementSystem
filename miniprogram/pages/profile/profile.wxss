.profile-page {
  background: linear-gradient(180deg, #f5f6f8 0%, #eef1f5 100%);
  min-height: 100vh;
  padding-bottom: 140rpx;
  box-sizing: border-box;
}

/* ===== 顶部 Hero ===== */
.profile-hero {
  background: linear-gradient(180deg, #0c0c0c 0%, #1a1a1a 100%);
  padding: 100rpx 32rpx 80rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 28rpx;
  position: relative;
}

.profile-hero::after {
  content: '';
  position: absolute;
  bottom: -60rpx;
  width: 100%;
  height: 120rpx;
  background: radial-gradient(circle, rgba(0,113,227,0.15) 0%, transparent 70%);
}

/* ===== 头像 ===== */
.avatar-wrap {
  position: relative;
}

.avatar-wrap:active {
  transform: scale(0.95);
}

.avatar {
  width: 170rpx;
  height: 170rpx;
  border-radius: 50%;
  border: 6rpx solid rgba(255,255,255,0.15);
  box-shadow: 0 10rpx 30rpx rgba(0,0,0,0.4);
}

.avatar-placeholder {
  width: 170rpx;
  height: 170rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.1);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 60rpx;
  color: #fff;
}

/* 编辑小角标 */
.avatar-edit-badge {
  position: absolute;
  bottom: 6rpx;
  right: 6rpx;
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: #0071e3;
  color: #fff;
  font-size: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* ===== 名字 ===== */
.profile-name {
  font-size: 42rpx;
  font-weight: 600;
  color: #ffffff;
}

/* ===== 角色标签 ===== */
.role-badge {
  background: rgba(255,255,255,0.08);
  color: rgba(255,255,255,0.85);
  padding: 10rpx 32rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
}

/* ===== 信息卡片 ===== */
.info-card {
  margin: -40rpx 32rpx 0;
  background: rgba(255,255,255,0.85);
  backdrop-filter: blur(20rpx);
  border-radius: 24rpx;
  box-shadow: 0 20rpx 60rpx rgba(0,0,0,0.08);
  overflow: hidden;
  transition: all 0.25s ease;
}

/* ===== 行 ===== */
.info-row {
  display: flex;
  align-items: center;
  padding: 24rpx 28rpx;
  border-bottom: 1rpx solid rgba(0,0,0,0.05);
  min-height: 100rpx;
  box-sizing: border-box;
}

.info-row:last-child {
  border-bottom: none;
}
.info-row:active {
  background: rgba(0,0,0,0.03);
}

/* ===== 左侧标题 ===== */
.info-k {
  width: 120rpx;
  font-size: 26rpx;
  color: rgba(0,0,0,0.6);
  flex-shrink: 0;
}

/* ===== 右侧内容 ===== */
.info-v {
  flex: 1;
  text-align: right;
  font-size: 28rpx;
  color: #111;
  font-weight: 500;
}

.info-v.empty {
  color: rgba(0,0,0,0.35);
}

.info-action {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 10rpx;
}

.info-action__text {
  font-size: 28rpx;
  color: #0071e3;
  font-weight: 600;
}

.info-action__arrow {
  font-size: 40rpx;
  color: rgba(0,0,0,0.28);
  line-height: 1;
}

.password-mask {
  position: fixed;
  inset: 0;
  z-index: 1000;
  background: rgba(0,0,0,0.36);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 48rpx;
  box-sizing: border-box;
}

.password-dialog {
  width: 100%;
  border-radius: 28rpx;
  background: #fff;
  padding: 34rpx 30rpx 28rpx;
  box-shadow: 0 24rpx 80rpx rgba(0,0,0,0.22);
  box-sizing: border-box;
}

.password-dialog__title {
  color: #111;
  font-size: 34rpx;
  font-weight: 700;
  margin-bottom: 24rpx;
}

.password-input {
  height: 84rpx;
  line-height: 84rpx;
  border-radius: 16rpx;
  background: #f4f6f9;
  color: #111;
  font-size: 28rpx;
  padding: 0 22rpx;
  box-sizing: border-box;
  margin-bottom: 18rpx;
}

.password-dialog__actions {
  display: flex;
  gap: 16rpx;
  margin-top: 8rpx;
}

.password-dialog__btn {
  flex: 1;
  margin: 0;
}

/* ===== 输入框 ===== */
.edit-input {
  flex: 1;
  text-align: right;
  font-size: 28rpx;
  color: #111;
  background: transparent;
  border: none;
  border-bottom: 2rpx solid transparent;
  padding-bottom: 4rpx;
  min-height: 40rpx;
  box-sizing: border-box;
}

.edit-input:focus {
  border-bottom: 2rpx solid #0071e3;
}

/* ===== 按钮区域 ===== */
.action-group {
  padding: 40rpx 32rpx 24rpx;
}

.primary-actions {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

/* ===== 编辑状态按钮（同行） ===== */
.edit-actions {
  display: flex;
  gap: 16rpx;
}

.edit-actions button {
  flex: 1;
}

/* ===== 主按钮（编辑资料 / 保存统一样式） ===== */
.btn-primary {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  padding: 0;
  margin: 0;
  background: linear-gradient(135deg, #0071e3, #4da3ff);
  color: #fff;
  border-radius: 14rpx;
  font-size: 30rpx;
  font-weight: 600;
  box-shadow: 0 8rpx 20rpx rgba(0,113,227,0.25);
  border: none;
}


/* ===== 次按钮 ===== */
.btn-outline {
  height: 88rpx;
  line-height: 88rpx;
  padding: 0;
  background: rgba(0,0,0,0.04);
  color: #333;
  border-radius: 14rpx;
  font-size: 30rpx;
}

/* ===== 底部退出登录 ===== */
.logout-fixed {
  position: fixed;
  left: 32rpx;
  right: 32rpx;
  bottom: 32rpx;
  padding-top: 16rpx;
}

.btn-logout {
  width: 100%;
  height: 72rpx;
  line-height: 72rpx;
  padding: 0;
  font-size: 26rpx;
  color: rgba(229,72,72,0.85);
  background: rgba(255,255,255,0.72);
  border-radius: 14rpx;
  border: 1rpx solid rgba(229,72,72,0.12);
  backdrop-filter: blur(12rpx);
}

/* ===== loading ===== */
.loading-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.35);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
}

.loading-spinner {
  width: 90rpx;
  height: 90rpx;
  border: 8rpx solid rgba(255,255,255,0.2);
  border-top-color: #0071e3;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}
