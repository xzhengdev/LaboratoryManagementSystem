.page {
  min-height: 100vh;
  padding: 30rpx 0 60rpx;
  background: linear-gradient(180deg, #f5f6f8 0%, #eef1f5 100%);
}

.filter-scroll {
  margin: 0 20rpx 16rpx;
}

.filter-tabs {
  display: flex;
  gap: 12rpx;
}

.filter-tab {
  padding: 10rpx 22rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  color: #51657f;
  background: rgba(255, 255, 255, 0.75);
  border: 1rpx solid rgba(255, 255, 255, 0.88);
}

.filter-tab.active {
  background: rgba(44, 125, 160, 0.88);
  color: #fff;
}

.search-row {
  display: grid;
  grid-template-columns: minmax(0, 1fr) auto;
  gap: 10rpx;
  margin: 0 20rpx 14rpx;
}

.search-input {
  height: 76rpx;
  border-radius: 16rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.85);
  background: rgba(255, 255, 255, 0.72);
  padding: 0 18rpx;
  font-size: 26rpx;
  color: #223246;
}

.search-btn {
  min-width: 110rpx;
  height: 76rpx;
  border-radius: 16rpx;
  background: #edf6ff;
  border: 1rpx solid #cfe4f7;
  color: #1f4f7d;
  font-size: 24rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
}

.overview {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 10rpx;
  margin: 0 20rpx 16rpx;
}

.overview-item {
  padding: 12rpx 8rpx;
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.74);
  border: 1rpx solid rgba(255, 255, 255, 0.9);
  box-shadow: 0 8rpx 20rpx rgba(0, 0, 0, 0.05);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
}

.overview-value {
  color: #0f2c4c;
  font-size: 34rpx;
  font-weight: 700;
  line-height: 1;
}

.overview-label {
  color: #5a6b7c;
  font-size: 20rpx;
}

.record-card {
  margin: 0 20rpx 14rpx;
  border-radius: 24rpx;
  padding: 24rpx;
  background: rgba(255, 255, 255, 0.7);
  backdrop-filter: blur(30rpx);
  -webkit-backdrop-filter: blur(30rpx);
  border: 1rpx solid rgba(255, 255, 255, 0.8);
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.08);
}

.record-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.record-name {
  color: #123355;
  font-size: 30rpx;
  font-weight: 700;
}

.record-row {
  margin-top: 6rpx;
  color: #4f6682;
  font-size: 23rpx;
}

.status-tag {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 700;
}

.status-pending {
  color: #ad7a00;
  background: #fff6e8;
}

.status-approved {
  color: #0f8a4b;
  background: #e8f8ee;
}

.status-rejected {
  color: #cc3f3f;
  background: #ffefef;
}

.empty-tip {
  text-align: center;
  margin-top: 140rpx;
  color: #8095ad;
  font-size: 24rpx;
}
