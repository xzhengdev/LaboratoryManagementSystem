/* ===== 页面背景（统一风格） ===== */
.detail-page {
  min-height: 100vh;
  background: linear-gradient(180deg, #f5f6f8 0%, #eef1f5 100%);
  padding-bottom: 140rpx;
}

/* ===== 顶部 Hero（高级感） ===== */
.hero {
  height: 300rpx;
  display: flex;
  align-items: center;
  padding: 0 32rpx;
  gap: 24rpx;

  background: linear-gradient(135deg, rgba(74,144,226,0.9), rgba(44,111,190,0.95));
}

/* 头像块 */
.hero-char {
  width: 110rpx;
  height: 110rpx;
  border-radius: 24rpx;

  background: rgba(255,255,255,0.2);
  backdrop-filter: blur(20rpx);

  display: flex;
  align-items: center;
  justify-content: center;

  font-size: 54rpx;
  color: #fff;
  font-weight: 700;
}

/* 信息 */
.hero-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.hero-name {
  font-size: 40rpx;
  font-weight: 700;
  color: #fff;
}

.hero-loc {
  font-size: 26rpx;
  color: rgba(255,255,255,0.85);
}

/* ===== Tabs（浮起来） ===== */
.tabs {
  margin: 16rpx 24rpx 12rpx;
  background: rgba(255,255,255,0.85);
  backdrop-filter: blur(20rpx);
  border-radius: 20rpx;
  display: flex;
  overflow: hidden;
  box-shadow: 0 10rpx 30rpx rgba(0,0,0,0.06);
}

.tab {
  flex: 1;
  text-align: center;
  padding: 22rpx 0;
  font-size: 28rpx;
  color: #888;
  transition: all 0.2s;
}

.tab.active {
  color: #0071e3;
  font-weight: 600;
  background: rgba(0,113,227,0.08);
}

/* ===== 通用卡片（统一） ===== */
.card {
  margin: 0 24rpx;
  background: rgba(255,255,255,0.92);
  backdrop-filter: blur(20rpx);
  border-radius: 24rpx;
  padding: 24rpx;

  box-shadow:
    0 12rpx 40rpx rgba(0,0,0,0.06),
    0 4rpx 12rpx rgba(0,0,0,0.04);
}

/* ===== 信息网格 ===== */
.info-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
}

.info-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
}

.info-val {
  font-size: 34rpx;
  font-weight: 700;
  color: #222;
}

.info-val.green { color: #27AE60; }
.info-val.gray  { color: #999; }

.info-key {
  font-size: 22rpx;
  color: #aaa;
}

/* ===== 标题 ===== */
.card-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #222;
  margin-bottom: 12rpx;
}

/* ===== 描述 ===== */
.desc-text {
  font-size: 26rpx;
  color: #666;
  line-height: 1.7;
}

/* ===== 设备 ===== */
.equip-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.equip-name {
  font-size: 28rpx;
  color: #333;
}

.equip-qty {
  font-size: 26rpx;
  color: #0071e3;
  font-weight: 600;
}

/* ===== 日期选择 ===== */
.date-picker-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.date-label {
  font-size: 28rpx;
  color: #555;
}

.date-val {
  font-size: 28rpx;
  color: #0071e3;
}

/* ===== 排期 ===== */
.schedule-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.schedule-time {
  font-size: 26rpx;
  color: #333;
  font-weight: 500;
  flex: 1;
}

.schedule-user {
  font-size: 24rpx;
  color: #888;
}

/* 状态标签 */
.status-tag {
  font-size: 22rpx;
  padding: 4rpx 14rpx;
  border-radius: 999rpx;
}

.status-approved {
  color: #27AE60;
  background: rgba(39,174,96,0.12);
}

.status-pending {
  color: #F5A623;
  background: rgba(245,166,35,0.12);
}

/* ===== 空状态 ===== */
.empty-tip {
  text-align: center;
  margin-top: 120rpx;
  color: #aaa;
}

/* ===== 底部按钮（优化版） ===== */
.reserve-bar {
  position: fixed;
  left: 24rpx;
  right: 24rpx;
  bottom: 24rpx;

  background: transparent;
}

.reserve-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 18rpx;

  background: linear-gradient(135deg, #0071e3, #4da3ff);
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;

  box-shadow:
    0 10rpx 28rpx rgba(0,113,227,0.25),
    inset 0 1rpx 0 rgba(255,255,255,0.3);
}

.reserve-btn::after {
  border: none;
}