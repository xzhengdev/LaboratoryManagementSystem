/* ===== 页面背景 ===== */
.detail-page {
  min-height: 100vh;
  padding-bottom: 168rpx;
  background:
    linear-gradient(180deg, #eef3f9 0%, #f7f9fc 52%, #f4f7fb 100%);
  box-sizing: border-box;
}

/* ===== Hero 顶部信息区 ===== */
.hero {
  margin: 20rpx 20rpx 0;
  min-height: 248rpx;
  padding: 28rpx 26rpx;
  box-sizing: border-box;
  border-radius: 30rpx;

  display: flex;
  align-items: center;
  gap: 22rpx;

  background:
    linear-gradient(135deg, rgba(74, 144, 226, 0.78), rgba(44, 111, 190, 0.88)),
    rgba(255, 255, 255, 0.18);
  backdrop-filter: blur(28rpx);
  -webkit-backdrop-filter: blur(28rpx);

  border: 1rpx solid rgba(255, 255, 255, 0.32);
  box-shadow:
    0 18rpx 48rpx rgba(33, 82, 145, 0.16),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.24);
}

/* 左侧字母块 */
.hero-char {
  width: 118rpx;
  height: 118rpx;
  flex-shrink: 0;
  border-radius: 28rpx;

  display: flex;
  align-items: center;
  justify-content: center;

  background: rgba(255, 255, 255, 0.18);
  backdrop-filter: blur(18rpx);
  -webkit-backdrop-filter: blur(18rpx);

  border: 1rpx solid rgba(255, 255, 255, 0.22);
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.28),
    0 10rpx 24rpx rgba(0, 0, 0, 0.08);

  font-size: 54rpx;
  line-height: 1;
  color: #fff;
  font-weight: 700;
}

/* 右侧信息 */
.hero-info {
  flex: 1;
  min-width: 0;

  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 10rpx;
}

.hero-name {
  font-size: 40rpx;
  line-height: 1.32;
  font-weight: 700;
  color: #fff;
}

.hero-loc {
  font-size: 25rpx;
  line-height: 1.5;
  color: rgba(255, 255, 255, 0.88);
}

/* ===== Tabs ===== */
.tabs {
  margin: 18rpx 20rpx 0;
  padding: 8rpx;
  border-radius: 24rpx;

  display: flex;
  align-items: center;
  box-sizing: border-box;

  background: rgba(255, 255, 255, 0.56);
  backdrop-filter: blur(24rpx);
  -webkit-backdrop-filter: blur(24rpx);

  border: 1rpx solid rgba(255, 255, 255, 0.72);
  box-shadow:
    0 12rpx 32rpx rgba(0, 0, 0, 0.05),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.9);
}

.tab {
  flex: 1;
  height: 72rpx;
  border-radius: 18rpx;

  display: flex;
  align-items: center;
  justify-content: center;

  font-size: 27rpx;
  color: #7b8796;
  transition: all 0.22s ease;
}

.tab.active {
  color: #0f5fc7;
  font-weight: 600;
  background: rgba(255, 255, 255, 0.72);
  box-shadow:
    0 6rpx 18rpx rgba(15, 95, 199, 0.08),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.95);
}

/* ===== 通用内容区间距 ===== */
.section-wrap {
  margin-top: 18rpx;
}

/* ===== 通用卡片 ===== */
.card {
  margin: 18rpx 20rpx 0;
  padding: 24rpx 22rpx;
  border-radius: 28rpx;
  box-sizing: border-box;

  background: rgba(255, 255, 255, 0.62);
  backdrop-filter: blur(28rpx);
  -webkit-backdrop-filter: blur(28rpx);

  border: 1rpx solid rgba(255, 255, 255, 0.82);
  box-shadow:
    0 14rpx 36rpx rgba(0, 0, 0, 0.055),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.92);
}

/* ===== 信息概览宫格 ===== */
.info-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18rpx;
}

.info-item {
  min-height: 116rpx;
  border-radius: 22rpx;
  padding: 18rpx 12rpx;
  box-sizing: border-box;

  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 10rpx;

  background: rgba(255, 255, 255, 0.42);
  border: 1rpx solid rgba(255, 255, 255, 0.72);
}

.info-val {
  font-size: 34rpx;
  line-height: 1.2;
  font-weight: 700;
  color: #1d2b38;
}

.info-val.green {
  color: #27AE60;
}

.info-val.gray {
  color: #8c97a6;
}

.info-key {
  font-size: 22rpx;
  line-height: 1.35;
  color: #8c98a8;
}

/* ===== 标题 ===== */
.card-title {
  display: block;
  margin-bottom: 14rpx;
  font-size: 28rpx;
  line-height: 1.35;
  font-weight: 600;
  color: #1c2d3f;
}

/* ===== 简介 ===== */
.desc-text {
  font-size: 25rpx;
  line-height: 1.8;
  color: #5f6f80;
}

/* ===== 设备列表 ===== */
.equip-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 20rpx;
}

.equip-name {
  flex: 1;
  min-width: 0;
  font-size: 28rpx;
  line-height: 1.45;
  color: #223246;
}

.equip-qty {
  flex-shrink: 0;
  min-width: 72rpx;
  text-align: right;
  font-size: 26rpx;
  line-height: 1.3;
  color: #0f5fc7;
  font-weight: 600;
}

/* ===== 日期选择器 ===== */
.date-picker-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 16rpx;
}

.date-label {
  font-size: 28rpx;
  line-height: 1.4;
  color: #506072;
}

.date-val {
  font-size: 28rpx;
  line-height: 1.4;
  color: #0f5fc7;
  font-weight: 500;
}

/* ===== 排期列表 ===== */
.schedule-item {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.schedule-time {
  flex: 1;
  min-width: 0;
  font-size: 26rpx;
  line-height: 1.45;
  color: #223246;
  font-weight: 600;
}

.schedule-user {
  max-width: 180rpx;
  font-size: 24rpx;
  line-height: 1.4;
  color: #7b8796;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

/* ===== 状态标签 ===== */
.status-tag {
  flex-shrink: 0;
  min-width: 88rpx;
  height: 42rpx;
  padding: 0 14rpx;
  box-sizing: border-box;
  border-radius: 999rpx;

  display: inline-flex;
  align-items: center;
  justify-content: center;

  font-size: 21rpx;
  font-weight: 600;

  border: 1rpx solid rgba(255, 255, 255, 0.62);
  backdrop-filter: blur(12rpx);
  -webkit-backdrop-filter: blur(12rpx);
}

.status-approved {
  color: #27AE60;
  background: rgba(39, 174, 96, 0.13);
}

.status-pending {
  color: #F5A623;
  background: rgba(245, 166, 35, 0.14);
}

/* ===== 空状态 ===== */
.empty-tip {
  margin: 132rpx 24rpx 0;
  text-align: center;
  font-size: 26rpx;
  line-height: 1.5;
  color: #98a2af;
}

/* ===== 底部浮动预约栏 ===== */
.reserve-bar {
  position: fixed;
  left: 24rpx;
  right: 24rpx;
  bottom: 50rpx;
  z-index: 20;
  background: transparent;
  border: none;
  box-shadow: none;
  padding: 0;
}
.reserve-btn {
  width: 40%;
  height: 92rpx;
  border-radius: 23rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  line-height: normal;
  background: linear-gradient(135deg, #0a74ea 0%, #4ea1ff 100%);
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
  letter-spacing: 1rpx;

  box-shadow:
    0 12rpx 30rpx rgba(10, 116, 234, 0.22),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.35);
}

.reserve-btn::after {
  border: none;
}

.reserve-btn:active {
  transform: scale(0.98);
  box-shadow:
    0 6rpx 16rpx rgba(10, 116, 234, 0.18),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.28);
}
