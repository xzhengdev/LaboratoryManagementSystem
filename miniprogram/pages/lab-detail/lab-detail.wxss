.detail-page { padding-bottom: 140rpx; }

.hero {
  height: 280rpx;
  display: flex;
  align-items: center;
  padding: 0 40rpx;
  gap: 28rpx;
}

.hero-char {
  width: 100rpx;
  height: 100rpx;
  border-radius: 20rpx;
  background: rgba(255,255,255,0.25);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 52rpx;
  color: #fff;
  font-weight: 700;
}

.hero-info { display: flex; flex-direction: column; gap: 10rpx; }

.hero-name { font-size: 40rpx; font-weight: 700; color: #fff; }
.hero-loc  { font-size: 26rpx; color: rgba(255,255,255,0.85); }

.tabs {
  display: flex;
  background: #fff;
  border-bottom: 1rpx solid #F0F4FA;
}

.tab {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  font-size: 28rpx;
  color: #888;
}

.tab.active {
  color: #4A90E2;
  font-weight: 600;
  border-bottom: 4rpx solid #4A90E2;
}

.info-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 24rpx;
}

.info-item { display: flex; flex-direction: column; align-items: center; gap: 6rpx; }
.info-val  { font-size: 36rpx; font-weight: 700; color: #222; }
.info-val.green { color: #27AE60; }
.info-val.gray  { color: #999; }
.info-key  { font-size: 22rpx; color: #aaa; }

.card-title { font-size: 28rpx; font-weight: 600; color: #333; display: block; margin-bottom: 12rpx; }
.desc-text  { font-size: 26rpx; color: #666; line-height: 1.7; }

.equip-item { display: flex; justify-content: space-between; align-items: center; }
.equip-name { font-size: 28rpx; color: #333; }
.equip-qty  { font-size: 26rpx; color: #4A90E2; font-weight: 600; }

.date-picker-row { display: flex; justify-content: space-between; align-items: center; }
.date-label { font-size: 28rpx; color: #555; }
.date-val   { font-size: 28rpx; color: #4A90E2; }

.schedule-item { display: flex; align-items: center; gap: 16rpx; }
.schedule-time { font-size: 26rpx; color: #333; font-weight: 500; flex: 1; }
.schedule-user { font-size: 24rpx; color: #888; }

.reserve-bar {
  position: fixed;
  bottom: 0; left: 0; right: 0;
  background: #fff;
  padding: 20rpx 32rpx;
  box-shadow: 0 -2rpx 12rpx rgba(0,0,0,0.08);
}

.reserve-btn { width: 100%; }
