<view class="campuses-page">
  <view wx:if="{{list.length===0}}" class="empty-tip">暂无校区数据</view>
  <view
    wx:for="{{list}}" wx:key="id"
    class="campus-card card"
    bindtap="goLabs" data-id="{{item.id}}"
  >
    <view class="campus-cover" style="background:{{item.color}}">
      <text class="campus-char">{{item.campus_name[0]}}</text>
    </view>
    <view class="campus-body">
      <text class="campus-name">{{item.campus_name}}</text>
      <text class="campus-addr">📍 {{item.address || '暂无地址'}}</text>
      <view class="campus-status {{item.status==='active'?'active':'inactive'}}">
        {{item.status==='active'?'运营中':'暂停'}}
      </view>
    </view>
    <text class="campus-arrow">›</text>
  </view>
</view>
