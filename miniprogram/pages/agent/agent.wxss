.agent-page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #F7F9FC;
}

.msg-list {
  flex: 1;
  padding: 24rpx 24rpx 0;
  overflow: hidden;
}

.msg-wrap {
  display: flex;
  flex-direction: column;
  margin-bottom: 24rpx;
}

.msg-wrap.user { align-items: flex-end; }
.msg-wrap.assistant { align-items: flex-start; }

.msg-bubble {
  max-width: 75%;
  padding: 20rpx 24rpx;
  border-radius: 20rpx;
  line-height: 1.6;
}

.msg-wrap.user .msg-bubble {
  background: #4A90E2;
  border-bottom-right-radius: 4rpx;
}
.msg-wrap.user .msg-text { color: #fff; font-size: 28rpx; }

.msg-wrap.assistant .msg-bubble {
  background: #fff;
  border-bottom-left-radius: 4rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
}
.msg-wrap.assistant .msg-text { color: #333; font-size: 28rpx; }

.action-btns { display: flex; flex-wrap: wrap; gap: 12rpx; margin-top: 12rpx; padding-left: 4rpx; }
.action-btn-item {
  padding: 10rpx 24rpx;
  background: #EBF4FF;
  color: #4A90E2;
  border-radius: 30rpx;
  font-size: 24rpx;
  font-weight: 500;
}

.quick-scroll { background: #fff; border-top: 1rpx solid #F0F4FA; }
.quick-list { display: flex; padding: 16rpx 24rpx; gap: 16rpx; white-space: nowrap; }
.quick-item {
  padding: 10rpx 24rpx;
  background: #F0F4FA;
  border-radius: 30rpx;
  font-size: 24rpx;
  color: #555;
  flex-shrink: 0;
}

.input-bar {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 16rpx 24rpx;
  background: #fff;
  border-top: 1rpx solid #F0F4FA;
}

.chat-input {
  flex: 1;
  height: 72rpx;
  background: #F7F9FC;
  border-radius: 36rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #333;
  border: 2rpx solid #E8EDF5;
}

.send-btn {
  padding: 16rpx 32rpx;
  background: #4A90E2;
  color: #fff;
  border-radius: 36rpx;
  font-size: 28rpx;
  font-weight: 500;
  flex-shrink: 0;
}
.send-btn.disabled { background: #B0C8E8; }
