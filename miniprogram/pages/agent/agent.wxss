.agent-page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: linear-gradient(180deg, #f5f6f8 0%, #eef1f5 100%);
}

/* 消息区 */
.msg-list {
  flex: 1;
  padding: 24rpx 20rpx 0;
  box-sizing: border-box;
}

.msg-wrap {
  display: flex;
  flex-direction: column;
  margin-bottom: 28rpx;
}

.msg-wrap.user {
  align-items: flex-end;
}

.msg-wrap.assistant {
  align-items: flex-start;
}

/* 气泡基础 */
.msg-bubble {
  max-width: 78%;
  padding: 22rpx 24rpx;
  border-radius: 24rpx;
  line-height: 1.7;
  box-sizing: border-box;
}

/* 用户气泡 */
.msg-wrap.user .msg-bubble {
  background: linear-gradient(135deg, #4a90e2, #6aa8f0);
  border-bottom-right-radius: 8rpx;
  box-shadow: 0 8rpx 20rpx rgba(74, 144, 226, 0.18);
}

.msg-wrap.user .msg-text {
  color: #ffffff;
  font-size: 28rpx;
  word-break: break-word;
}

/* 助手气泡 */
.msg-wrap.assistant .msg-bubble {
  background: rgba(255, 255, 255, 0.9);
  backdrop-filter: blur(16rpx);
  border-bottom-left-radius: 8rpx;
  box-shadow:
    0 10rpx 30rpx rgba(0, 0, 0, 0.06),
    0 4rpx 12rpx rgba(0, 0, 0, 0.03);
}

.msg-wrap.assistant .msg-text {
  color: #222;
  font-size: 28rpx;
  word-break: break-word;
}

/* 助手操作按钮 */
.action-btns {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 14rpx;
  padding-left: 4rpx;
}

.action-btn-item {
  padding: 12rpx 24rpx;
  background: rgba(255, 255, 255, 0.88);
  color: #4a90e2;
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 500;
  border: 1rpx solid rgba(74, 144, 226, 0.14);
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.04);
}

.action-btn-item:active {
  transform: scale(0.97);
  background: #ebf4ff;
}

/* 快捷问题区域 */
.quick-scroll {
  margin: 0 16rpx 0;
  border-radius: 20rpx 20rpx 0 0;
  background: rgba(255, 255, 255, 0.82);
  backdrop-filter: blur(16rpx);
  border-top: 1rpx solid rgba(255, 255, 255, 0.7);
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.04);
}

.quick-list {
  display: flex;
  padding: 16rpx 20rpx;
  gap: 14rpx;
  white-space: nowrap;
}

.quick-item {
  padding: 10rpx 22rpx;
  background: #f2f4f7;
  border-radius: 999rpx;
  font-size: 24rpx;
  color: #555;
  flex-shrink: 0;
  border: 1rpx solid rgba(0, 0, 0, 0.04);
}

.quick-item:active {
  background: #eaf2ff;
  color: #4a90e2;
}

/* 输入区 */
.input-bar {
  display: flex;
  align-items: center;
  gap: 14rpx;
  padding: 16rpx 16rpx 20rpx;
  background: rgba(255, 255, 255, 0.92);
  backdrop-filter: blur(20rpx);
  border-top: 1rpx solid rgba(0, 0, 0, 0.04);
  box-shadow: 0 -6rpx 20rpx rgba(0, 0, 0, 0.04);
}

/* 输入框 */
.chat-input {
  flex: 1;
  height: 76rpx;
  background: #f5f7fa;
  border-radius: 38rpx;
  padding: 0 26rpx;
  font-size: 28rpx;
  color: #333;
  border: 2rpx solid #e6ebf2;
  box-sizing: border-box;
}

/* 发送按钮 */
.send-btn {
  min-width: 120rpx;
  height: 76rpx;
  line-height: 76rpx;
  text-align: center;
  background: linear-gradient(135deg, #4a90e2, #6aa8f0);
  color: #fff;
  border-radius: 38rpx;
  font-size: 28rpx;
  font-weight: 600;
  flex-shrink: 0;
  box-shadow: 0 8rpx 20rpx rgba(74, 144, 226, 0.2);
}

.send-btn.disabled {
  background: linear-gradient(135deg, #bfd4ee, #c9dcf3);
  color: rgba(255, 255, 255, 0.95);
  box-shadow: none;
}