page {
  background: #e9edf3;
}


.agent-page {
  position: relative;
  display: flex;
  flex-direction: column;
  height: 100vh;
  min-height: 100vh;
  overflow: hidden;
  background: #e9edf3;
}

.chat-main {
  flex: 1;
  min-height: 0;
  overflow: hidden;
}

.msg-list {
  height: 100%;
  min-height: 0;
  padding: 24rpx 18rpx 170rpx;
  box-sizing: border-box;
}

.msg-wrap {
  margin-bottom: 28rpx;
}

.msg-row {
  display: flex;
  align-items: flex-start;
  gap: 14rpx;
}

.msg-wrap.user .msg-row {
  justify-content: flex-end;
}

.msg-wrap.assistant .msg-row {
  justify-content: flex-start;
}

.avatar {
  width: 68rpx;
  height: 68rpx;
  border-radius: 50%;
  flex-shrink: 0;
  overflow: hidden;
  box-shadow: 0 8rpx 18rpx rgba(0, 0, 0, 0.08);
}

.assistant-avatar-wrap {
  background: #ffffff;
  border: 2rpx solid rgba(255, 255, 255, 0.75);
}

.assistant-avatar {
  width: 100%;
  height: 100%;
  display: block;
}

.user-avatar-wrap {
  background: linear-gradient(135deg, #4a90e2, #6aa8f0);
  border: 2rpx solid rgba(255, 255, 255, 0.82);
}

.user-avatar,
.user-avatar-fallback {
  width: 100%;
  height: 100%;
}

.user-avatar-fallback {
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 28rpx;
  font-weight: 700;
}

.msg-content {
  max-width: 72%;
  display: flex;
  flex-direction: column;
}

.msg-bubble {
  padding: 22rpx 24rpx;
  border-radius: 26rpx;
  box-sizing: border-box;
}

.msg-wrap.user .msg-bubble {
  background: linear-gradient(135deg, #4a90e2, #6aa8f0);
  border-bottom-right-radius: 10rpx;
  box-shadow: 0 10rpx 22rpx rgba(74, 144, 226, 0.18);
}

.msg-wrap.assistant .msg-bubble {
  background: rgba(255, 255, 255, 0.82);
  border: 1rpx solid rgba(255, 255, 255, 0.88);
  border-bottom-left-radius: 10rpx;
  box-shadow: 0 12rpx 28rpx rgba(0, 0, 0, 0.05);
}

.msg-text {
  font-size: 28rpx;
  line-height: 1.7;
  word-break: break-word;
}

.msg-wrap.user .msg-text {
  color: #ffffff;
}

.msg-wrap.assistant .msg-text {
  color: #1f2d3d;
}

.typing-bubble {
  display: flex;
  align-items: center;
  gap: 8rpx;
  width: 100rpx;
  min-height: 40rpx;
}

.typing-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: #9eb1c8;
  animation: typing 1.2s infinite ease-in-out;
}

.typing-dot:nth-child(2) {
  animation-delay: 0.2s;
}

.typing-dot:nth-child(3) {
  animation-delay: 0.4s;
}

@keyframes typing {
  0%,
  80%,
  100% {
    transform: scale(0.8);
    opacity: 0.5;
  }
  40% {
    transform: scale(1);
    opacity: 1;
  }
}

.action-btns {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 14rpx;
  padding-left: 2rpx;
}

.action-btn-item {
  padding: 12rpx 22rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.9);
  border: 1rpx solid rgba(74, 144, 226, 0.12);
  color: #4a90e2;
  font-size: 24rpx;
  font-weight: 500;
}

.action-btn-item:active {
  transform: scale(0.97);
  background: #ebf4ff;
}

.input-bar {
  position: absolute;
  left: 16rpx;
  right: 16rpx;
  bottom: calc(16rpx + env(safe-area-inset-bottom));
  display: flex;
  align-items: center;
  gap: 14rpx;
  padding: 0;
  background: transparent;
  border: none;
  box-shadow: none;
  box-sizing: border-box;
  z-index: 10;
}

.chat-input {
  flex: 1;
  height: 78rpx;
  padding: 0 26rpx;
  border-radius: 40rpx;
  background: rgba(255, 255, 255, 0.92);
  border: 1rpx solid rgba(82, 102, 130, 0.16);
  box-sizing: border-box;
  font-size: 28rpx;
  color: #333;
  box-shadow: 0 8rpx 24rpx rgba(27, 49, 77, 0.12);
}

.chat-placeholder {
  color: #a0a8b5;
}

.send-btn {
  min-width: 156rpx;
  height: 78rpx;
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 24rpx;
  box-sizing: border-box;
  background: rgba(255, 255, 255, 0.72);
  border: 1rpx solid rgba(82, 102, 130, 0.2);
  color: #30445d;
  font-size: 28rpx;
  font-weight: 600;
  flex-shrink: 0;
  box-shadow: 0 8rpx 24rpx rgba(27, 49, 77, 0.12);
}

.send-btn.disabled {
  color: #9aa8bb;
  background: rgba(255, 255, 255, 0.55);
  border-color: rgba(82, 102, 130, 0.12);
  box-shadow: none;
}

