<view class="agent-page">
  <view class="chat-main">
    <scroll-view
      scroll-y
      class="msg-list"
      scroll-into-view="{{scrollAnchor}}"
      scroll-with-animation
      enhanced
      show-scrollbar="false"
    >
      <view
        wx:for="{{messages}}"
        wx:key="id"
        class="msg-wrap {{item.role}}"
        id="msg-{{item.id}}"
      >
        <view class="msg-row">
          <view wx:if="{{item.role === 'assistant'}}" class="avatar assistant-avatar-wrap">
            <image class="assistant-avatar" src="/assets/logo.png" mode="aspectFill" />
          </view>

          <view class="msg-content">
            <view class="msg-bubble">
              <text class="msg-text">{{item.content}}</text>
            </view>

            <view wx:if="{{item.actions && item.actions.length}}" class="action-btns">
              <view
                wx:for="{{item.actions}}"
                wx:key="path"
                wx:for-item="action"
                class="action-btn-item"
                bindtap="goAction"
                data-path="{{action.path}}"
              >
                {{action.label}}
              </view>
            </view>
          </view>

          <view wx:if="{{item.role === 'user'}}" class="avatar user-avatar-wrap">
            <image wx:if="{{userAvatar}}" class="user-avatar" src="{{userAvatar}}" mode="aspectFill" />
            <view wx:else class="user-avatar-fallback">{{userInitial}}</view>
          </view>
        </view>
      </view>

      <view wx:if="{{typing}}" class="msg-wrap assistant" id="typing-bubble">
        <view class="msg-row">
          <view class="avatar assistant-avatar-wrap">
            <image class="assistant-avatar" src="/assets/logo.png" mode="aspectFill" />
          </view>
          <view class="msg-content">
            <view class="msg-bubble typing-bubble">
              <view class="typing-dot"></view>
              <view class="typing-dot"></view>
              <view class="typing-dot"></view>
            </view>
          </view>
        </view>
      </view>
    </scroll-view>
  </view>

  <scroll-view scroll-x class="quick-scroll" show-scrollbar="false">
    <!-- <view class="quick-list">
      <view
        wx:for="{{quickPrompts}}"
        wx:key="index"
        class="quick-item"
        bindtap="sendQuick"
        data-text="{{item}}"
      >
        {{item}}
      </view>
    </view> -->
  </scroll-view>

  <view class="input-bar">
    <input
      class="chat-input"
      placeholder="例如：明天下午2点有哪些实验室空闲？"
      placeholder-class="chat-placeholder"
      value="{{draft}}"
      bindinput="onDraft"
      confirm-type="send"
      bindconfirm="sendMessage"
      cursor-spacing="20"
    />
    <view class="send-btn {{canSend ? '' : 'disabled'}}" bindtap="sendMessage">
      {{sending ? '发送中...' : '发送'}}
    </view>
  </view>
</view>

