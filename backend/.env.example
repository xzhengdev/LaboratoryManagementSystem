SECRET_KEY=replace-with-a-strong-secret-key
JWT_SECRET_KEY=replace-with-a-strong-jwt-secret-key

# Database (priority: DATABASE_URL > MYSQL_* > sqlite fallback)
DATABASE_URL=
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=replace-with-your-db-password
MYSQL_DB=lab_reservation

# Agent / LLM
AGENT_PROVIDER=rule
AGENT_MODEL=gpt-4o-mini
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1/chat/completions
AGENT_DEBUG_TRACE=0

# Distributed lock / idempotency
REDIS_URL=
ENABLE_DISTRIBUTED_LOCK=0
REDIS_LOCK_TTL_SECONDS=15
REDIS_LOCK_WAIT_TIMEOUT_SECONDS=3
REDIS_LOCK_RETRY_INTERVAL_SECONDS=0.1
ENABLE_IDEMPOTENCY=1
IDEMPOTENCY_TTL_SECONDS=300
LAB_SCHEDULE_CACHE_TTL_SECONDS=30
STATISTICS_CACHE_TTL_SECONDS=45
ENABLE_RATE_LIMIT=0
RATE_LIMIT_CREATE_RESERVATION_PER_MIN=30
RATE_LIMIT_APPROVE_RESERVATION_PER_MIN=60
RATE_LIMIT_CREATE_ASSET_REQUEST_PER_MIN=20
RATE_LIMIT_SUBMIT_DAILY_REPORT_PER_MIN=30

# Distributed file storage (SeaweedFS optional)
SEAWEEDFS_UPLOAD_URL=
SEAWEEDFS_WRITE_URL=
SEAWEEDFS_PUBLIC_URL=
SEAWEEDFS_TIMEOUT_SECONDS=8
# Campus-level SeaweedFS map (JSON), takes priority over global SEAWEEDFS_*.
# Example:
# SEAWEEDFS_CAMPUS_CONFIG_MAP={"5":{"upload_url":"http://127.0.0.1:19335","write_url":"http://127.0.0.1:18085","public_url":"http://127.0.0.1:18085"},"6":{"upload_url":"http://127.0.0.1:19336","write_url":"http://127.0.0.1:18086","public_url":"http://127.0.0.1:18086"}}
SEAWEEDFS_CAMPUS_CONFIG_MAP=

# Campus-level physical sharding (optional)
ENABLE_CAMPUS_DB_ROUTING=0
CAMPUS_DB_URI_MAP=
SUMMARY_DB_URL=

# Async events (stage C)
ENABLE_ASYNC_EVENTS=0
ASYNC_EVENT_QUEUE_NAME=lab:events
ASYNC_EVENT_BLOCK_TIMEOUT_SECONDS=5

# Recommended for distributed & high-concurrency demo:
# REDIS_URL=redis://127.0.0.1:6379/0
# ENABLE_DISTRIBUTED_LOCK=1
# ENABLE_RATE_LIMIT=1
# ENABLE_ASYNC_EVENTS=1
